# Executive OS Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://executive_os:secure_password@localhost:5432/executive_os
DB_USER=executive_os
DB_PASSWORD=secure_password
DB_NAME=executive_os
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Clairis Configuration
CLAIRIS_EMAIL=your_clairis_email@example.com
CLAIRIS_PASSWORD=your_clairis_password
CLAIRIS_BASE_URL=https://clairis.example.com

# Pipedrive Configuration
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token
PIPEDRIVE_BASE_URL=https://api.pipedrive.com

# Security Configuration
ENCRYPTION_MASTER_KEY=generate_with_python_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key().decode()
SECRET_KEY=your_secret_key_for_jwt

# Email Configuration (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@executive-os.local

# Monitoring & Logging
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Feature Flags
ENABLE_API_KEY_AUTH=true
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
ENABLE_METRICS=true

# Worker Configuration
WORKER_THREADS=4
BATCH_SIZE=100
MAX_WORKERS=10

# SSL/TLS Configuration (for production)
SSL_CERTFILE=/etc/letsencrypt/live/domain.example.com/fullchain.pem
SSL_KEYFILE=/etc/letsencrypt/live/domain.example.com/privkey.pem
SSL_CA_CERTS=/etc/letsencrypt/live/domain.example.com/chain.pem
