# BACKUP TEMPLATE - Copie este arquivo e preencha com os valores reais
# NUNCA commite o arquivo .env com credenciais reais!
# As credenciais reais estão protegidas em .gitignore

# ============================================
# Pipedrive CRM API
# ============================================
PIPEDRIVE_TOKEN=seu_token_aqui

# ============================================
# Meta (Facebook) Ads
# ============================================
FB_ACCESS_TOKEN=seu_token_aqui
FB_AD_ACCOUNT_IDS=id1,id2,id3

# ============================================
# Tintim WhatsApp Integration
# ============================================
TINTIM_ACCOUNT_CODE=seu_code_aqui
TINTIM_ACCOUNT_TOKEN=seu_token_aqui

# ============================================
# Google Ads (Opcional)
# ============================================
GOOGLE_ADS_CUSTOMER_ID=seu_customer_id
GOOGLE_ADS_DEVELOPER_TOKEN=seu_developer_token
GOOGLE_ADS_REFRESH_TOKEN=seu_refresh_token

# ============================================
# Google OAuth (Opcional - para integração futura)
# ============================================
GOOGLE_OAUTH_CLIENT_ID=seu_client_id
GOOGLE_OAUTH_CLIENT_SECRET=seu_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://app.viveraorofacial.com.br/auth/callback
GOOGLE_API_KEY=sua_api_key

# ============================================
# OpenAI (Opcional - para resumos IA)
# ============================================
OPENAI_API_KEY=sk-...

# ============================================
# WhatsApp Database (Local)
# ============================================
WHATSAPP_DB_HOST=127.0.0.1
WHATSAPP_DB_PORT=3306
WHATSAPP_DB_USER=root
WHATSAPP_DB_PASSWORD=
WHATSAPP_DB_NAME=vivera_whatsapp

# ============================================
# Server
# ============================================
PORT=3000
