# Configuração do servidor
PORT=3000

# Pipedrive - Token da API
# Obtenha em: https://app.pipedrive.com/user/settings
PIPEDRIVE_TOKEN=seu_token_aqui

# Meta Ads API (Facebook Ads Manager)
FB_ACCESS_TOKEN=seu_token_aqui
FB_AD_ACCOUNT_IDS=act_123456789,act_987654321

# Notas sobre o painel /sdr (Corrida das SDRs):
# - O arquivo dashboard-sdr.html contém constantes para o funil Vivera Orofacial
# - AGENDAMENTO_STAGE = 4 (stage do funil para agendamentos)
# - COMPARECIMENTO_STAGE = 5 (stage do funil para comparecimentos)
# - CRC_FIELD = 'fd9cfb07956d6227f9e50b9be8b20ab176d17ce7' (campo customizado "Origem")
# - jessica tag = usado para categorizar fechamentos
# Se o seu funil é diferente, ajuste estas constantes no topo do <script> em dashboard-sdr.html
