# Nao precisa preencher isso a mao: rode `bash setup.sh` na raiz desta pasta
# que ele gera o .env inteiro sozinho (senhas aleatorias, sobe o banco em
# Docker, tenta mapear os usuarios do Pipedrive). Isso aqui e so referencia.

PORT=4001

# MySQL - por padrao aponta pro container whatsapp-db do docker-compose.yml
# (schema aplicado automaticamente no primeiro start via sql/schema.sql)
DB_HOST=whatsapp-db
DB_USER=whatsapp_monitor
DB_PASSWORD=
DB_NAME=vivera_whatsapp

# Pipedrive (mesmo token usado no resto do projeto - o setup.sh reaproveita
# automaticamente o que estiver no .env da raiz do repo)
PIPEDRIVE_TOKEN=

# Webhook do n8n que roda a analise diaria de aderencia ao script (POST { action, sdr, script, conversations })
N8N_WEBHOOK=

# Segredo do cookie de sessao - gerar algo aleatorio, ex: openssl rand -hex 32
SESSION_SECRET=

# Senha de acesso de cada SDR ao proprio painel (/login)
SDR_PASSWORD_HELENICE=
SDR_PASSWORD_AGDA=
