PORT=4001

# MySQL - rodar sql/schema.sql nesse banco antes de subir
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=vivera_whatsapp

# Pipedrive (mesmo token usado no resto do projeto)
PIPEDRIVE_TOKEN=

# Webhook do n8n que roda a analise diaria de aderencia ao script (POST { action, sdr, script, conversations })
N8N_WEBHOOK=

# Segredo do cookie de sessao - gerar algo aleatorio, ex: openssl rand -hex 32
SESSION_SECRET=

# Senha de acesso de cada SDR ao proprio painel (/login)
SDR_PASSWORD_HELENICE=
SDR_PASSWORD_AGDA=
