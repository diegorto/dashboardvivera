# Rode `bash setup.sh` nesta pasta - ele preenche sozinho tudo que puder
# (SESSION_SECRET, senhas dos SDRs, N8N_WEBHOOK, reaproveita o PIPEDRIVE_TOKEN
# da raiz do repo) sem mexer no que voce ja tiver preenchido aqui. Isso aqui e
# so referencia do formato esperado.

PORT=4001

# MySQL - se ja existe um container (ex: vivera-mysql), o DB_HOST so resolve
# por esse nome se a app rodar DENTRO da mesma rede Docker; rodando via
# "npm start" direto no host, use DB_HOST=127.0.0.1 (com a porta publicada
# pro host, ex: 3306:3306).
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=vivera_whatsapp

# Pipedrive (mesmo token usado no resto do projeto - o setup.sh reaproveita
# automaticamente o que estiver no .env da raiz do repo)
PIPEDRIVE_TOKEN=

# Webhook do n8n que roda a analise diaria de aderencia ao script (POST { action, sdr, script, conversations })
N8N_WEBHOOK=

# Segredo do cookie de sessao - gerar algo aleatorio, ex: openssl rand -hex 32
SESSION_SECRET=

# Senha de acesso de cada SDR ao proprio painel (/login)
SDR_PASSWORD_HELENICE=
SDR_PASSWORD_AGDA=
